{
  "name": "schedule-ui",
  "version": "1.3.0",
  "description": "Home Assistant Lovelace custom cards for schedule and timer helpers, with auto-generated automation bridges.",
  "main": "timer-schedule-card.js",
  "type": "module",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "dev": "http-server . -p 8080 --silent",
    "smoke": "node scripts/smoke.js",
    "screenshot": "node scripts/run-screenshot.js",
    "ha:up": "docker compose up -d",
    "ha:down": "docker compose down",
    "ha:logs": "docker compose logs -f homeassistant",
    "ha:restart": "docker compose restart homeassistant",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jewon-oh/schedule-ui.git"
  },
  "keywords": [
    "home-assistant",
    "hacs",
    "lovelace",
    "custom-card",
    "schedule",
    "timer"
  ],
  "author": "jewon-oh",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jewon-oh/schedule-ui/issues"
  },
  "homepage": "https://github.com/jewon-oh/schedule-ui#readme",
  "dependencies": {
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "http-server": "^14.1.1",
    "playwright": "^1.60.0",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  }
}
