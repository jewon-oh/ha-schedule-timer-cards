{
  "name": "ha-schedule-timer-cards",
  "version": "1.8.1",
  "packageManager": "pnpm@11.2.2",
  "description": "Home Assistant Lovelace custom cards for schedule and timer helpers, with auto-generated automation bridges.",
  "main": "timer-schedule-card.js",
  "type": "module",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "dev": "http-server . -p 8080 --silent",
    "test:bridge": "node --experimental-strip-types scripts/bridge-roundtrip.test.mjs",
    "smoke": "node --experimental-strip-types scripts/bridge-roundtrip.test.mjs && node scripts/smoke.js",
    "changelog": "npx -y git-cliff -o CHANGELOG.md",
    "changelog:preview": "npx -y git-cliff --latest --strip header",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "screenshot": "node scripts/run-screenshot.js",
    "ha:up": "docker compose up -d",
    "ha:down": "docker compose down",
    "ha:logs": "docker compose logs -f homeassistant",
    "ha:restart": "docker compose restart homeassistant",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jewon-oh/ha-schedule-timer-cards.git"
  },
  "keywords": [
    "home-assistant",
    "hacs",
    "lovelace",
    "custom-card",
    "schedule",
    "timer"
  ],
  "author": "jewon-oh",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jewon-oh/ha-schedule-timer-cards/issues"
  },
  "homepage": "https://github.com/jewon-oh/ha-schedule-timer-cards#readme",
  "dependencies": {
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "http-server": "^14.1.1",
    "js-yaml": "^4.1.1",
    "playwright": "^1.60.0",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  }
}
